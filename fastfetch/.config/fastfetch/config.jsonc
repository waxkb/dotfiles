// execute with: fastfetch --colors-block-range-start 9 --colors-block-width 3

{
    "$schema": "https://github.com/fastfetch-cli/fastfetch/raw/dev/doc/json_schema.json",
    "logo": {
        "source": "arch_small"
    },
    "display": {
        "separator": " "
    },
    "modules": [
        {
            "type": "os",
            "key": " ",
            "keyColor": "#ffb3b0"  // = color3
        },
        {
            "type": "wm",
            "key": " ",
            "keyColor": "#ffb3b0"
        },
        {
            "type": "terminal",
            "key": " ",
            "keyColor": "#ffb3b0"
        },
        {
            "type": "shell",
            "key": " ",
            "keyColor": "#ffb3b0"
        },
        "break",
        "colors",
        "break",
        "break"
    ]
}
