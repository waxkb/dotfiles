#!/bin/bash
# Apply a Steam Wallpaper Engine wallpaper
we_id="$1"

if [ -z "$we_id" ]; then
  echo "Error: missing WE id" >&2
  exit 1
fi

config_dir="${XDG_CONFIG_HOME:-$HOME/.config}/quickshell"
cache_dir="${XDG_CACHE_HOME:-$HOME/.cache}/quickshell-wallpaper-picker"

we_dir=$(jq -r '.paths.steamWorkshop // ""' "$config_dir/data/config.json" 2>/dev/null | sed "s|~|$HOME|")
wall_dir=$(jq -r '.paths.wallpaper // ""' "$config_dir/data/config.json" 2>/dev/null | sed "s|~|$HOME|")

echo '{"type":"we","we_id":"'"$we_id"'"}' > "$cache_dir/last-wallpaper.json"

# Kill existing wallpaper processes
pkill awww-daemon 2>/dev/null
pkill awww 2>/dev/null
pkill mpvpaper 2>/dev/null

# Try to launch linux-wallpaperengine if available
if command -v linux-wallpaperengine >/dev/null 2>&1 && [ -d "$we_dir/$we_id" ]; then
  linux-wallpaperengine --silent --no-fullscreen-pause --noautomute "$we_id" &
fi

# Copy preview image to wallpaper.jpg
if [ -n "$wall_dir" ] && [ -d "$we_dir/$we_id" ]; then
  preview=$(find "$we_dir/$we_id" -maxdepth 1 -iname 'preview.*' -type f 2>/dev/null | head -1)
  if [ -n "$preview" ]; then
    cp "$preview" "$wall_dir/wallpaper.jpg" 2>/dev/null
  fi
fi

exit 0
