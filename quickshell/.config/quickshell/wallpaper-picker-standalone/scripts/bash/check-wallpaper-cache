#!/bin/bash
# Simplified wallpaper cache builder - just list wallpapers and generate thumbnails

CACHE_VERSION=2

. "$(dirname "$0")/lib.sh"

scripts_dir="$PIIXIDENT_CONFIG/scripts"
wall_dir=$(cfg_get '.paths.wallpaper')
cache_dir="$PIIXIDENT_CACHE/wallpaper/thumbs"
video_cache="$PIIXIDENT_CACHE/wallpaper/video-thumbs"
combined_list="$PIIXIDENT_CACHE/wallpaper/list.jsonl"
checksum_file="$PIIXIDENT_CACHE/wallpaper/checksum.txt"
version_file="$PIIXIDENT_CACHE/wallpaper/cache-version.txt"

mkdir -p "$cache_dir" "$video_cache"

# Invalidate cache on version bump
stored_version=$(cat "$version_file" 2>/dev/null)
if [ "$stored_version" != "$CACHE_VERSION" ]; then
  rm -f "$combined_list" "$checksum_file"
  echo "$CACHE_VERSION" > "$version_file"
fi

# Compute file checksums
if [ -d "$wall_dir" ]; then
  static_check=$(find "$wall_dir" -maxdepth 1 -type f \( -iname '*.jpg' -o -iname '*.jpeg' -o -iname '*.png' -o -iname '*.webp' \) ! -name 'wallpaper.jpg' -printf '%f %T@\n' 2>/dev/null | sort)
  video_check=$(find "$wall_dir" -maxdepth 1 -type f \( -iname '*.mp4' -o -iname '*.webm' -o -iname '*.mkv' \) -printf '%f %T@\n' 2>/dev/null | sort)
else
  static_check=""
  video_check=""
fi

current_checksum=$(echo "$static_check$video_check" | md5sum | cut -d' ' -f1)
stored_checksum=$(cat "$checksum_file" 2>/dev/null)

if [ "$current_checksum" = "$stored_checksum" ] && [ -f "$combined_list" ]; then
  echo "cached"
  exit 0
fi

# Clear and rebuild
> "$combined_list"

# Process static images
if [ -d "$wall_dir" ]; then
  shopt -s nullglob
  for ext in jpg jpeg png webp JPG JPEG PNG WEBP; do
    for img in "$wall_dir"/*."$ext"; do
      [ -f "$img" ] || continue
      name=$(basename "$img")
      [[ "$name" == "wallpaper.jpg" ]] && continue
      
      mtime=$(stat -c '%Y' "$img" 2>/dev/null || echo "0")
      thumb_name="${name%.*}.jpg"
      thumb_path="$cache_dir/$thumb_name"
      
      # Generate thumbnail if needed
      if [ ! -f "$thumb_path" ]; then
        if command -v convert >/dev/null 2>&1; then
          convert "$img" -resize 930x540^ -gravity center -extent 930x540 "$thumb_path" 2>/dev/null
        elif command -v ffmpeg >/dev/null 2>&1; then
          ffmpeg -y -i "$img" -vf "scale=930:540:force_original_aspect_ratio=decrease,pad=930:540:(ow-iw)/2:(oh-ih)/2" "$thumb_path" 2>/dev/null
        fi
      fi
      
      # Extract dominant hue (simplified)
      hue=0
      sat=0
      if command -v convert >/dev/null 2>&1; then
        colors=$(convert "$img" -resize 1x1 -format "%[fx:u.r*5],%[fx:u.g*5],%[fx:u.b*5]" txt:- 2>/dev/null | tail -1 | grep -oP '\d+\.\d+')
        if [ -n "$colors" ]; then
          r=$(echo "$colors" | cut -d, -f1)
          g=$(echo "$colors" | cut -d, -f2)
          b=$(echo "$colors" | cut -d, -f3)
          max=$(echo "$r $g $b" | tr ' ' '\n' | sort -n | tail -1)
          min=$(echo "$r $g $b" | tr ' ' '\n' | sort -n | head -1)
          if [ "$max" != "0" ]; then
            sat=$(echo "scale=2; ($max - $min) / $max" | bc 2>/dev/null || echo "0")
          fi
          if [ "$max" != "$min" ]; then
            if [ "$max" = "$r" ]; then
              hue=$(echo "scale=0; (($g - $b) / ($max - $min) + 6) * 2" | bc 2>/dev/null || echo "0")
            elif [ "$max" = "$g" ]; then
              hue=$(echo "scale=0; (($b - $r) / ($max - $min) + 2) * 2" | bc 2>/dev/null || echo "0")
            else
              hue=$(echo "scale=0; (($r - $g) / ($max - $min) + 4) * 2" | bc 2>/dev/null || echo "0")
            fi
            hue=$(echo "$hue % 12" | bc 2>/dev/null || echo "0")
          fi
        fi
      fi
      
      echo "{\"type\":\"static\",\"name\":\"$name\",\"thumb\":\"$thumb_path\",\"path\":\"$img\",\"mtime\":$mtime,\"group\":$hue,\"sat\":$sat}" >> "$combined_list"
    done
  done

  # Process videos
  for ext in mp4 webm mkv MP4 WEBM MKV; do
    for video in "$wall_dir"/*."$ext"; do
      [ -f "$video" ] || continue
      name=$(basename "$video")
      mtime=$(stat -c '%Y' "$video" 2>/dev/null || echo "0")
      thumb_name="${name%.*}.jpg"
      thumb_path="$video_cache/$thumb_name"
      
      if [ ! -f "$thumb_path" ] && command -v ffmpeg >/dev/null 2>&1; then
        ffmpeg -y -i "$video" -ss 00:00:01 -vframes 1 -vf "scale=930:540:force_original_aspect_ratio=decrease,pad=930:540:(ow-iw)/2:(oh-ih)/2" "$thumb_path" 2>/dev/null
      fi
      
      echo "{\"type\":\"video\",\"name\":\"$name\",\"thumb\":\"$thumb_path\",\"path\":\"$video\",\"videoFile\":\"$video\",\"mtime\":$mtime,\"group\":6,\"sat\":0}" >> "$combined_list"
    done
  done
  shopt -u nullglob
fi

echo "$current_checksum" > "$checksum_file"
echo "regenerated"
