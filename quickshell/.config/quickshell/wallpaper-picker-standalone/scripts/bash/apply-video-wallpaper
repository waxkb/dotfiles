#!/bin/bash
# Apply a video wallpaper
wall_path="$1"

if [ -z "$wall_path" ] || [ ! -f "$wall_path" ]; then
  echo "Error: invalid video path: $wall_path" >&2
  exit 1
fi

config_dir="${XDG_CONFIG_HOME:-$HOME/.config}/quickshell"
cache_dir="${XDG_CACHE_HOME:-$HOME/.cache}/quickshell-wallpaper-picker"

echo '{"type":"video","path":"'"$wall_path"'"}' > "$cache_dir/last-wallpaper.json"

# Kill existing video wallpaper
pkill -9 mpvpaper 2>/dev/null
pkill -9 -f linux-wallpaperengine 2>/dev/null

# Try mpvpaper (for Wayland)
if command -v mpvpaper >/dev/null 2>&1; then
  mpvpaper -o "--loop --no-audio --panscan=1" DP-1 "$wall_path" &
elif command -v mpv >/dev/null 2>&1 && command -v xdotool >/dev/null 2>&1; then
  mpv --loop --no-audio --wid=$(xdotool getactivewindow) "$wall_path" &
fi

exit 0
