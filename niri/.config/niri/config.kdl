// Niri configuration emulating the provided Hyprland binds.conf and autostart.conf
// Notes:
// - $mainMod (SUPER) -> Mod
// - Hyprland-specific actions are mapped to closest Niri equivalents
// - Some Hyprland features (dwindle split toggle, special workspaces) do not exist in Niri
//   and are approximated or omitted with comments.

input {
    keyboard {
        xkb {
            layout "us"
        }
    }
}

spawn-at-startup {
    command "systemctl" "--user" "start" "hyprpolkitagent"
    command "waybar"
    command "swww-daemon"
    command "swww" "restore"
    command "hyprsunset"
    command "clipse" "-listen"
}

// --------------------
// Key bindings
// --------------------

binds {
    // Application launchers
    Mod+B { spawn "zen-browser" }
    Mod+Shift+B { spawn "kitty" "btop" }
    Mod+C { spawn "kitty" "--class" "clipse" "-e" "clipse" }
    Mod+E { spawn "kitty" "sudo" "yazi" }
    Mod+F { spawn "kitty" "-e" "zsh" "-i" "-c" "fastfetch; exec zsh" }
    Mod+M { spawn "spotify-launcher" }
    Mod+N { spawn "kitty" "nvim" }
    Mod+O { spawn "hyprlock" "-q" "--immediate-render" "--no-fade-in" }
    Mod+Shift+O { spawn "kitty" "obs" }
    Mod+P { spawn "hyprpicker" }
    Mod+Shift+S { spawn "hyprshot" "-o" "$HOME/screenshots" "-z" "-m" "region" }
    Mod+S { spawn "sh" "-c" "killall hyprsunset; hyprsunset" }
    Mod+V { spawn "vesktop" }
    Mod+W { spawn "sh" "-c" "killall waybar; waybar" }
    Mod+Shift+W { spawn "waypaper" }
    Mod+X { spawn "$HOME/.config/niri/power-menu.zsh" }
    Mod+Y { spawn "$HOME/.config/niri/mpv-url" }
    Mod+Return { spawn "kitty" }
    Mod+Space { spawn "rofi" "-show" "run" }

    // Window management
    Mod+D { close-window }
    Mod+Shift+D { quit }
    Mod+T { toggle-floating }

    // Focus movement (vim-style)
    Mod+H { focus left }
    Mod+L { focus right }
    Mod+K { focus up }
    Mod+J { focus down }

    // Move windows
    Mod+Shift+H { move left }
    Mod+Shift+L { move right }
    Mod+Shift+K { move up }
    Mod+Shift+J { move down }

    // Workspaces
    Mod+1 { focus-workspace 1 }
    Mod+2 { focus-workspace 2 }
    Mod+3 { focus-workspace 3 }
    Mod+4 { focus-workspace 4 }
    Mod+5 { focus-workspace 5 }
    Mod+6 { focus-workspace 6 }
    Mod+7 { focus-workspace 7 }
    Mod+8 { focus-workspace 8 }
    Mod+9 { focus-workspace 9 }
    Mod+0 { focus-workspace 10 }

    Mod+Shift+1 { move-to-workspace 1 }
    Mod+Shift+2 { move-to-workspace 2 }
    Mod+Shift+3 { move-to-workspace 3 }
    Mod+Shift+4 { move-to-workspace 4 }
    Mod+Shift+5 { move-to-workspace 5 }
    Mod+Shift+6 { move-to-workspace 6 }
    Mod+Shift+7 { move-to-workspace 7 }
    Mod+Shift+8 { move-to-workspace 8 }
    Mod+Shift+9 { move-to-workspace 9 }
    Mod+Shift+0 { move-to-workspace 10 }

    // Workspace cycling (mouse wheel equivalent)
    Mod+WheelDown { focus-workspace next }
    Mod+WheelUp { focus-workspace previous }

    // Media keys
    XF86AudioRaiseVolume { spawn "wpctl" "set-volume" "-l" "1" "@DEFAULT_AUDIO_SINK@" "5%+" }
    XF86AudioLowerVolume { spawn "wpctl" "set-volume" "@DEFAULT_AUDIO_SINK@" "5%-" }
    XF86AudioMute { spawn "wpctl" "set-mute" "@DEFAULT_AUDIO_SINK@" "toggle" }
    XF86AudioMicMute { spawn "wpctl" "set-mute" "@DEFAULT_AUDIO_SOURCE@" "toggle" }
    XF86MonBrightnessUp { spawn "brightnessctl" "-e4" "-n2" "set" "5%+" }
    XF86MonBrightnessDown { spawn "brightnessctl" "-e4" "-n2" "set" "5%-" }

    XF86AudioNext { spawn "playerctl" "next" }
    XF86AudioPlay { spawn "playerctl" "play-pause" }
    XF86AudioPause { spawn "playerctl" "play-pause" }
    XF86AudioPrev { spawn "playerctl" "previous" }
}
```
