spawn-at-startup "zen"
spawn-at-startup "spotify"
spawn-at-startup "vesktop"
spawn-sh-at-startup "sleep 0.75; niri msg action focus-workspace 1"
spawn-at-startup "activate-linux"
spawn-sh-at-startup "systemctl --user start hyprpolkitagent"
spawn-sh-at-startup "clipse -listen"
spawn-at-startup "swww-daemon"
spawn-sh-at-startup "swww restore"
spawn-sh-at-startup "vicinae server"
hotkey-overlay {
  skip-at-startup
}
