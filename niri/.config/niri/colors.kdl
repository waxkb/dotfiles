layout {
    gaps 8
    focus-ring {
        off
        active-color "#e1b7f5"
        inactive-color "#ffffff"
        width 2
    }

    border {
        on
        width 2
        active-color "#e1b7f5"
        inactive-color "#161217"
        urgent-color "#ffb4ab"
    }

    shadow {
        off
        softness 30
        spread 5
        offset x=0 y=5
        color "#0007"
    }
    always-center-single-column
}
