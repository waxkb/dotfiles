layout {
    gaps 6
    focus-ring {
        off
        active-color "#e1c46d"
        inactive-color "#ffffff"
        width 2
    }

    border {
        on
        width 2
        active-color "#e1c46d"
        inactive-color "#16130b"
        urgent-color "#ffb4ab"
    }

    shadow {
        off
        softness 30
        spread 5
        offset x=0 y=5
        color "#0007"
    }
    always-center-single-column
}
